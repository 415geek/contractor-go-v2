SUPABASE_URL=http://127.0.0.1:55321
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Clerk 第三方认证（Supabase config.toml 中 auth.third_party.clerk 使用）
CLERK_DOMAIN=clerk.contractorgo.io

# Voip.ms（Phase 2 虚拟号码，需在 Voip.ms 控制台配置 IP 白名单或允许所有 IP）
VOIPMS_USERNAME=your-voipms-email@example.com
VOIPMS_PASSWORD=your-voipms-api-password
# 可选：固定 IP 中继（见 docs/VOIP_IP_WHITELIST.md）。不设则直连 voip.ms。
# VOIP_RELAY_URL=https://your-vps.example.com/voip
# 勿写成 …io./voip（io 与 / 之间多点会导致 DNS 失败）
# VOIP_RELAY_SECRET=与 relay 服务 RELAY_SECRET 一致（强烈建议开启）
# 可选：Voip HTTP 超时毫秒（默认 120000）。直连/中继均适用。
# VOIP_HTTP_TIMEOUT_MS=120000

# OpenAI（Chat：项目解析、生成计划、翻译、材料视觉、房屋估价视觉、Permit 解析；Whisper：项目语音转文字）
OPENAI_API_KEY=your-openai-api-key
# 可选：覆盖默认聊天/视觉模型（默认 gpt-4o-mini）
# OPENAI_CHAT_MODEL=gpt-4o
