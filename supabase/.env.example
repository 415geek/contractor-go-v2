SUPABASE_URL=http://127.0.0.1:55321
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Clerk 第三方认证（Supabase config.toml 中 auth.third_party.clerk 使用）
CLERK_DOMAIN=clerk.contractorgo.io
# 可选：Edge `get-user` 内用 @clerk/backend verifyToken 校验 Session（JWE 等）；不设则仍尝试手动解码 3 段 JWT
# 生产若 Session 为 JWE（5 段），必须配置其一：
# CLERK_SECRET_KEY=sk_live_...
# CLERK_JWT_KEY=-----BEGIN PUBLIC KEY-----...（Dashboard → API Keys → JWT verification key，Edge 无网络拉 JWKS 时推荐）
# 可选：verifyToken 的 authorizedParties（逗号分隔，无空格）
# CLERK_AUTHORIZED_PARTIES=https://www.contractorgo.io,https://contractorgo.io

# Telnyx（虚拟号码：搜索/订购/发短信）https://developers.telnyx.com/docs/overview
TELNYX_API_KEY=KEYxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 可选：订购号码时绑定 Messaging Profile（必须为 UUID，勿填 KEY… 的 API Key）
# TELNYX_MESSAGING_PROFILE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# 可选：若需语音连接，绑定 Connection ID（UUID）
# TELNYX_CONNECTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# 可选：HTTP 超时毫秒（默认 120000）
# TELNYX_HTTP_TIMEOUT_MS=120000

# Stripe（订阅 → 更新 public.users.subscription_tier，见 docs/STRIPE_SETUP.md）
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID_PRO=price_...
# PUBLIC_APP_URL=https://www.contractorgo.io

# OpenAI（Chat：项目解析、生成计划、翻译、材料视觉、房屋估价视觉、Permit 解析；Whisper：项目语音转文字）
OPENAI_API_KEY=your-openai-api-key
# 可选：覆盖默认聊天/视觉模型（默认 gpt-4o-mini）
# OPENAI_CHAT_MODEL=gpt-4o
